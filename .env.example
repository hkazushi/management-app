# ---------------------------------------------------------------------------
# このファイルは「変数名のテンプレート」です。実値は書かないでください。
# 実値は .env.local（gitignore 済み）にコピーして記入します。
#   cp .env.example .env.local
# ---------------------------------------------------------------------------

# Supabase（公開しても安全な値。ブラウザに露出してOK）
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Anthropic API（AIサマリー生成用 / spec §3.4）
# サーバー側（Route Handler）でのみ使用。NEXT_PUBLIC_ を付けない＝クライアントに露出させない。
ANTHROPIC_API_KEY=

# --- アクセス制御（サーバー側のみ。NEXT_PUBLIC は付けない）---
# 画面で打つPIN（例: 0408）。アカウントごとに別PIN。
APP_PIN=
APP_AUTH_EMAIL=
APP_AUTH_PASSWORD=
# 2つ目のアカウント（マルチユーザー）。別PIN → 別Supabaseアカウント（別ワークスペース）。
APP_PIN_2=
APP_AUTH_EMAIL_2=
APP_AUTH_PASSWORD_2=

# --- Google カレンダー連携（OAuth・サーバー側のみ）---
# Google Cloud Console で作成した OAuth クライアント。承認済みリダイレクトURIに
#   https://<本番>/api/google/callback と http://localhost:3000/api/google/callback を登録。
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ※ Claude Code フック連携（spec §6）で使う Supabase サービスキーは、
#   Web アプリとは別管理（フック用のローカル環境変数）にします。ここには置きません。
