# フック用の認証情報テンプレート（spec §6.3）
# 実体は ~/.claude/hooks/management-app.env に置く（リポジトリにコミットしない）。
#   cp hooks/management-app.env.example ~/.claude/hooks/management-app.env
#   chmod 600 ~/.claude/hooks/management-app.env

# Supabase プロジェクトURL
SUPABASE_URL=

# サービス（secret）キー。RLS を越えて書き込むためサーバー専用。絶対に公開しない。
SUPABASE_SERVICE_KEY=

# 書き込み先の user_id（あなたのアカウントのUUID）。
# サービスキーでは auth.uid() が null になるため明示する必要がある。
MANAGEMENT_USER_ID=
